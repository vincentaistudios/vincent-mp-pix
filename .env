# 🚀 VINCENT-MP-PIX - CONFIGURAÇÕES
# Desenvolvido por Vincent AI Studios (2026)

# =========================================================================
# 🔑 CREDENCIAIS DO MERCADO PAGO
# =========================================================================
# Obtenha seu Token em: https://www.mercadopago.com.br/developers/panel/app
# IMPORTANTE: Seu token deve começar com "APP_USR-..."
# =========================================================================

MP_ACCESS_TOKEN=APP_USR-SEU-TOKEN-AQUI


# =========================================================================
# ⚙️ CONFIGURAÇÕES ADICIONAIS (OPCIONAL)
# =========================================================================
# Defina o tempo padrão de expiração (em minutos) se não for enviado no código.
# Padrão Pix: 30 minutos | Padrão Boleto: 1440 minutos (24h)
DEFAULT_EXPIRATION_TIME=30


# =========================================================================
